{
  "name": "@uqrealitylabs/feelable-materials",
  "version": "0.1.0",
  "description": "Tactile React Three Fiber material surfaces for cloth, rubber, glass, grass, and touchable logos.",
  "type": "module",
  "license": "GPL-3.0-only",
  "packageManager": "npm@11.12.1",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "check:no-js": "node scripts/assert-no-js.ts",
    "check:workflows": "node scripts/assert-actions-pinned.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format:check": "biome format .",
    "test": "vitest run --config vitest.config.ts --coverage.enabled true",
    "test:coverage": "npm run test",
    "test:r3f": "npm run test",
    "test:component": "npm run test",
    "prebuild": "rm -rf dist",
    "build": "tsc -p tsconfig.build.json",
    "package:check": "npm pack --dry-run --cache /tmp/npm-cache",
    "pack:check": "npm run package:check",
    "test:consumer": "node scripts/consumer-smoke.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uqrealitylabs/feelable-materials.git"
  },
  "bugs": {
    "url": "https://github.com/uqrealitylabs/feelable-materials/issues"
  },
  "homepage": "https://github.com/uqrealitylabs/feelable-materials#readme",
  "keywords": [
    "react-three-fiber",
    "threejs",
    "materials",
    "webgl",
    "interaction"
  ],
  "peerDependencies": {
    "@react-three/fiber": ">=9 <10",
    "react": ">=19 <20",
    "three": ">=0.170 <1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.7",
    "@react-three/fiber": "^9.4.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.7",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "react": "^19.2.1",
    "react-test-renderer": "^19.2.1",
    "three": "^0.185.1",
    "typescript": "^7.0.2",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.19"
  }
}
