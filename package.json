{
  "name": "@uqrealitylabs/feelable-materials",
  "version": "0.3.0",
  "description": "Tactile React Three Fiber materials that crease, compress, smudge, bend, and react to touch.",
  "type": "module",
  "license": "GPL-3.0-only",
  "packageManager": "npm@11.12.1",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    }
  },
  "scripts": {
    "repo:check": "npm run repo:check:layout && npm run check:no-js",
    "repo:check:layout": "node tools/scripts/repo/validate-layout.ts",
    "config:check": "npm run release:validate",
    "check:no-js": "node tools/scripts/assert-no-js.ts",
    "check:workflows": "node tools/scripts/assert-actions-pinned.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "test": "npm run test:coverage",
    "test:unit": "vitest run --config tools/config/vitest.config.ts",
    "test:coverage": "vitest run --config tools/config/vitest.config.ts --coverage.enabled true",
    "test:r3f": "npm run test:unit",
    "test:component": "npm run test:unit",
    "test:ci": "npm run repo:check && npm run typecheck && npm run lint && npm run format:check && npm run test:coverage && npm run build && npm run test:consumer && npm run package:check && npm run demo:build && npm run test:demo",
    "prebuild": "rm -rf dist",
    "build": "tsc -p tools/config/tsconfig.build.json",
    "demo:dev": "npm run demo:build && vite --config tools/config/demo-vite.config.ts",
    "demo:build": "npm run build && npm run demo:typecheck:built && vite build --config tools/config/demo-vite.config.ts",
    "demo:preview": "npm run demo:build && vite preview --config tools/config/demo-vite.config.ts",
    "demo:typecheck:built": "tsc --noEmit --project tools/config/tsconfig.demo.json",
    "test:demo": "node tools/scripts/demo/validate-demo.ts",
    "package:check": "npm pack --dry-run --cache /tmp/npm-cache",
    "pack:check": "npm run package:check",
    "test:consumer": "node tools/scripts/consumer-smoke.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:osv": "node tools/scripts/security/osv-audit.ts",
    "release:validate": "node tools/scripts/release/validate-codenames.ts",
    "release:codename": "node tools/scripts/release/generate-codename.ts",
    "wiki:check": "node tools/scripts/wiki/validate-wiki.ts",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uqrealitylabs/feelable-materials.git"
  },
  "bugs": {
    "url": "https://github.com/uqrealitylabs/feelable-materials/issues"
  },
  "homepage": "https://github.com/uqrealitylabs/feelable-materials#readme",
  "keywords": [
    "react-three-fiber",
    "threejs",
    "materials",
    "webgl",
    "interaction"
  ],
  "peerDependencies": {
    "@react-three/fiber": ">=9 <10",
    "react": ">=19 <20",
    "three": ">=0.170 <1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@react-three/fiber": "^9.4.0",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-test-renderer": "^19.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.7",
    "react-test-renderer": "^19.2.1",
    "three": "^0.185.1",
    "typescript": "^7.0.2",
    "vite": "^6.4.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=20.19"
  }
}
