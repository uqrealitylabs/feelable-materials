# Unreal ignore snippet.
# Use for Unreal Engine projects.
# Do not ignore Config, Content, Source, Plugins source, or .uproject files.

.vs/
Binaries/
Saved/
Intermediate/
Plugins/**/Intermediate/
DerivedDataCache/

/*.sln
/*.slnx
*.suo
/*.opensdf
/*.sdf
*.VC.db
*.VC.opendb
/*.xcodeproj
/*.xcworkspace

*.obj
*.pdb
*.ilk
*.exp
